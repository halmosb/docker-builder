FROM docker.io/nvidia/cuda:{{ cuda_version }}-cudnn-runtime-ubuntu{{ ubuntu }}

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

ARG USERNAME=dev
ARG UID=1000
ARG GID=1000

# ----------------------------
# System dependencies
# ----------------------------
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        vim-nox \
        git \
        build-essential \
        curl \
    && rm -rf /var/lib/apt/lists/*

# ----------------------------
# Create user (same as CPU image)
# ----------------------------
RUN groupadd -g ${GID} ${USERNAME} && \
    useradd -m -u ${UID} -g ${GID} -s /bin/bash ${USERNAME}

# ----------------------------
# Workspace
# ----------------------------
RUN mkdir -p /workspace && chown ${USERNAME}:${USERNAME} /workspace
WORKDIR /workspace

# ----------------------------
# Python (system Python + pip bootstrap)
# ----------------------------
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-dev python3-venv && \
    rm -rf /var/lib/apt/lists/*

RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3

RUN pip install --no-cache-dir --upgrade pip setuptools wheel ipython matplotlib && \
    pip install --no-cache-dir \
        torch torchvision torchaudio \
        --index-url {{ pytorch_gpu_index }}

# ----------------------------
# Switch to user
# ----------------------------
USER ${USERNAME}
ENV HOME=/home/${USERNAME}

RUN git config --global --add safe.directory /workspace

# ----------------------------
# Git config (same as CPU)
# ----------------------------
RUN git config --global core.editor "vim" && \
    git config --global alias.lga "log --all --graph --decorate --oneline" && \
    git config --global alias.lg "log --graph --decorate --oneline"

# ----------------------------
# Vim setup (same as CPU)
# ----------------------------
RUN curl -fLo ${HOME}/.vim/autoload/plug.vim --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim

COPY --chown=${USERNAME}:${USERNAME} templates/.vimrc_template ${HOME}/.vimrc

RUN vim +PlugInstall +qall

# ----------------------------
# Default command
# ----------------------------
CMD ["python3"]