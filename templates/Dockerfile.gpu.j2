FROM docker.io/nvidia/cuda:{{ cuda_version }}-cudnn-runtime-ubuntu{{ ubuntu }}

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

ARG USERNAME=dev
ARG UID=1000
ARG GID=1000
LABEL org.opencontainers.image.description GPU Docker image with python {{ python_version }}.

# ----------------------------
# System dependencies
# ----------------------------
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        software-properties-common \
        build-essential \
        curl \
        git \
        vim \
        wl-clipboard \
        ca-certificates \
    && add-apt-repository ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python{{ python_version }} \
        python{{ python_version }}-dev \
        python{{ python_version }}-venv \
    && rm -rf /var/lib/apt/lists/*

# Make python3 point to chosen version
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python{{ python_version }} 1

# Ensure pip
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3

# Upgrade core Python tooling
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# ----------------------------
# Create user
# ----------------------------
RUN groupadd -g ${GID} ${USERNAME} && \
    useradd -m -u ${UID} -g ${GID} -s /bin/bash ${USERNAME}

# ----------------------------
# Workspace
# ----------------------------
RUN mkdir -p /workspace && chown ${USERNAME}:${USERNAME} /workspace
WORKDIR /workspace

# ----------------------------
# Python packages (GPU stack)
# ----------------------------
# NOTE: assumes CUDA-compatible PyTorch index is provided
RUN pip install --no-cache-dir \
        ipython matplotlib numpy scipy pandas \
    && pip install --no-cache-dir \
        torch torchvision torchaudio

# ----------------------------
# Switch to user
# ----------------------------
USER ${USERNAME}
ENV HOME=/home/${USERNAME}

# ----------------------------
# Git config
# ----------------------------
RUN git config --global --add safe.directory /workspace && \
    git config --global core.editor "vim" && \
    git config --global alias.lga "log --all --graph --decorate --oneline" && \
    git config --global alias.lg "log --graph --decorate --oneline"

# ----------------------------
# Vim setup
# ----------------------------
RUN curl -fLo ${HOME}/.vim/autoload/plug.vim --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim

COPY --chown=${USERNAME}:${USERNAME} templates/.vimrc_template ${HOME}/.vimrc

RUN vim +PlugInstall +qall

# ----------------------------
# Default shell
# ----------------------------
CMD ["python3"]